	mi,thermal_gl = "17600,15000,12000,9000,8000,7000,6000,5000,4000,3500,3000,2400,2000,1600,1000,500";

	mi,cycle_volt_cn_nvt = "0,100,4200,4300,4400,4500,4580,100,300,4170,4270,4400,4500,4560,300,800,4170,4270,4400,4500,4550,800,10000,4170,4270,4400,4500,4530,";
