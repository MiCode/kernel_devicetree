/*
  this file is for attribution only of flourite
  And public attribution of xiaomi platforms(like flourite and so and)
*/
#include "flourite-pinctrl.dtsi"
#include "xiaomi-sm7635-common.dtsi"
#include "volcano-pm7550ba.dtsi"
#include <dt-bindings/iio/qcom,spmi-adc5-gen3-pmxr2230.h>
#include "flourite-sm7635-xiaomi-fingerprint.dtsi"
#include "flourite-sm7635-xiaomi-hdbds.dtsi"

/* SENSOR start */
&qupv3_se3_spi {
	status = "ok";
	pinctrl-names = "default", "sleep";
	pinctrl-0 = <&qupv3_se3_spi_mosi_active>;
	pinctrl-1 = <&qupv3_se3_spi_sleep>;
	ir-spi@0 {
		compatible = "ir-spi";
		reg = <0>;
		spi-max-frequency = <19200000>;
		status = "ok";
	};
};

&tlmm {
	qupv3_se3_spi_mosi_active: qupv3_se3_spi_mosi_active {
		mux {
			pins = "gpio16";
			function = "qup0_se3_l1";
		};

		config {
			pins = "gpio16";
			drive-strength = <6>;
			bias-disable;
		};
	};

	qupv3_se3_spi_sleep: qupv3_se3_spi_sleep {
		mux {
			pins = "gpio16";
			function = "gpio";
		};

		config {
			pins = "gpio16";
			drive-strength = <2>;
			bias-disable;
		};
	};
};
/* SENSOR end */

/*modem start: t1 chip*/
&soc {
        mi_t1_chip {
                compatible = "mdm,mi_t1_chip";
                gpio-wwan-wlan-1 = <&tlmm 136 0x0>;
                gpio-wwan-wlan-2 = <&tlmm 119 0x0>;
                pinctrl-0       = <&t1_gpio_ctl>;
        };
};

&tlmm {
	t1_gpio_ctl: t1_gpio_ctl {
		mux {
			pins = "gpio136", "gpio119";
			function = "gpio";
		};
		config {
			pins = "gpio136", "gpio119";
			drive-strength = <2>;
			bias-disable;
			output-enable;
		};
	};
};
/*modem end: t1 chip*/


/*touch start*/
&soc {
	xiaomi_touch {
		compatible = "xiaomi-touch";
		status = "ok";
		touch,name = "xiaomi-touch";
	};
};

&qupv3_se0_i2c {
	status = "disable";
};

&tlmm {
	mi_ts_spi_miso_active: mi_ts_spi_miso_active {
		mux {
			pins = "gpio0";
			function = "qup0_se0_l0";
		};
		config {
			pins = "gpio0";
			drive-strength = <6>;
			bias-disable;
		};
	};
	mi_ts_spi_mosi_active: mi_ts_spi_mosi_active {
		mux {
			pins = "gpio1";
			function = "qup0_se0_l1";
		};
		config {
			pins = "gpio1";
			drive-strength = <6>;
			bias-disable;
		};
	};
	mi_ts_spi_clk_active: mi_ts_spi_clk_active {
		mux {
			pins = "gpio2";
			function = "qup0_se0_l2";
		};
		config {
			pins = "gpio2";
			drive-strength = <6>;
			bias-disable;
		};
	};
	mi_ts_spi_cs_active: mi_ts_spi_cs_active {
		mux {
			pins = "gpio3";
			function = "qup0_se0_l3";
		};
		config {
			pins = "gpio3";
			drive-strength = <6>;
			bias-disable;
		};
	};
	mi_ts_spi_cs_suspend: mi_ts_spi_cs_suspend {
		mux {
			pins = "gpio3";
			function = "gpio";
		};
		config {
			pins = "gpio3";
			drive-strength = <2>;
			bias-pull-down;
			output-low;
		};
	};
	mi_ts_spi_sleep: mi_ts_spi_sleep {
		mux {
			pins = "gpio0", "gpio1";
			function = "gpio";
		};
		config {
			pins = "gpio0", "gpio1";
			drive-strength = <2>;
			output-low;
			bias-disable;
		};
	};
	mi_ts_clk_sleep: mi_ts_clk_sleep {
		mux {
			pins = "gpio2";
			function = "gpio";
		};
		config {
			pins = "gpio2";
			drive-strength = <2>;
			bias-pull-down;
		};
	};
};

&qupv3_se0_spi {
	status = "ok";
	qcom,rt;
	pinctrl-0 = <&mi_ts_spi_mosi_active>, <&mi_ts_spi_miso_active>,
				<&mi_ts_spi_clk_active>;
	pinctrl-1 = <&mi_ts_spi_sleep>, <&mi_ts_clk_sleep>;
	//qcom,la-vm;
	/* Novatek device tree node */
	novatek@0 {
		compatible = "novatek,NVT-ts-spi";
		reg = <0>; //Same as CS ID
		status = "ok";
		spi-max-frequency = <19200000>;	//4800000,9600000,15000000,19200000

		novatek,irq-gpio = <&tlmm 70 0x2008>;
		novatek,lcd_id-gpio1 = <&tlmm 65 0x00>;
		novatek,lcd_id-gpio2 = <&tlmm 128 0x00>;
		spi-cs-setup-delay-ns = <300>;
		spi-cs-hold-delay-ns = <300>;
		pinctrl-0 = <&mi_ts_spi_cs_active>;
		pinctrl-1 = <&mi_ts_spi_cs_suspend>;
		pinctrl-names = "pmx_ts_active", "pmx_ts_suspend";

		/* MP */
		novatek,mp-support-dt;

		/* for Xiaomi flourite NT38771 CSOT6.83" panel module */
