/* NFC start:  tms + nxp*/
&qupv3_se1_i2c {
	status = "ok";
 	#address-cells = <1>;
	#size-cells = <0>;
	nfc@28 {
		clock-frequency = <400000>;
		status = "ok";
		compatible = "tms,nfc";
		reg = <0x28>;
		tms,device-name   = "tms_nfc";
		tms,device-count  = <1>;
		tms,irq-gpio      = <&tlmm 31 0x00>;
		tms,ven-gpio      = <&tlmm 7 0x00>;
		tms,download-gpio = <&tlmm 81 0x00>;
		tms,clkreq-gpio   = <&tlmm 6 0x00>;

		nxp,sn-ven-rstn   = <&tlmm 7 0x00>;
		nxp,sn-clkreq     = <&tlmm 6 0x00>;
		nxp,sn-irq        = <&tlmm 31 0x00>;
	};
};
/* NFC end */

/* USB start */
&pm7550ba_eusb2_repeater {
	qcom,param-override-seq =
		<0x00 0x50
		0x09 0x51
		0x01 0x52
		0x07 0x53
		0x01 0x54
		0x02 0x55
		0x00 0x56
		0x05 0x57
		0x02 0x58
		0x03 0x59
		0x01 0x5a
		0x02 0x5b>;
	qcom,param-override-seq-host-ms =
		<0x00 0x50
		0x0e 0x51
		0x01 0x52
		0x07 0x53
		0x01 0x54
		0x00 0x55
		0x00 0x56
		0x00 0x57
		0x02 0x58
		0x03 0x59
		0x01 0x5a
		0x02 0x5b>;
	qcom,param-override-seq-host =
		<0x00 0x50
		0x0e 0x51
		0x01 0x52
		0x07 0x53
		0x01 0x54
		0x03 0x55
		0x00 0x56
		0x07 0x57
		0x02 0x58
		0x03 0x59
		0x01 0x5a
		0x02 0x5b>;
};
/* USB end */

&usb0 {
    dwc3@a600000 {
        usb-phy = <&eusb2_phy0>, <&usb_nop_phy>;
        maximum-speed = "high-speed";
    };
};

&usb_qmp_dp_phy {
    status="disabled";
};

&battery_charger {
	qcom,shutdown-voltage = <2950>;
	mi,support-shutdown-delay;
	mi,support-ut-test;
	mi,support-ut-test-region;
	mi,support-ut-test-multi-volt;

	mi,cycle_volt_gl_nvt = "0,100,4130,4230,4400,4500,4580,100,300,4100,4200,4400,4500,4560,300,800,4100,4200,4400,4500,4550,800,10000,4100,4200,4400,4500,4530,";
