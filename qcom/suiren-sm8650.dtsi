&soc {
	thermal-message {
 		board-sensor = "VIRTUAL-SENSOR0";
	};

	extcon_usb: extcon-usb {
		status = "ok";
		compatible = "xm,xm-extcon-usb-gpio";
		id-gpio = <&tlmm 197 GPIO_ACTIVE_HIGH>;
		pinctrl-names = "default";
		pinctrl-0 = <&usb_id_default>;
	};

	usb_nop_phy:usb_nop_phy{
		compatible = "usb-nop-xceiv";
	};
};
&usb0 {
	extcon = <&extcon_usb>, <&extcon_usb>;
	qcom,wcd_usbss = <&wcd_usbss>;
	dwc3@a600000 {
		usb-phy = <&eusb2_phy0>, <&usb_nop_phy>;
		maximum-speed = "high-speed";
	};
};
&usb_qmp_dp_phy {
	status = "disabled";
};
&wcd_usbss {
	wcd-equ-bw-settings = <0xF>;
	wcd-equ-bw-settings-new = <0x0>;
};
&pm8550b_eusb2_repeater {
 qcom,param-override-seq-host =
		<0x00 0x50
		0x0E 0x51
		0x04 0x52
		0x07 0x53
		0x01 0x54
		0x01 0x55
		0x03 0x56
		0x07 0x57
		0x02 0x58
		0x01 0x59
		0x03 0x5a
		0x02 0x5b>;
	qcom,param-override-seq =
		<0x00 0x50
		0x0A 0x51
		0x04 0x52
		0x07 0x53
		0x00 0x54
		0x00 0x55
		0x00 0x56
		0x00 0x57
		0x02 0x58
		0x03 0x59
		0x01 0x5a
		0x02 0x5b>;
	qcom,param-override-seq-new =
		<0x00 0x50
		0x0E 0x51
		0x04 0x52
		0x07 0x53
		0x01 0x54
		0x01 0x55
		0x03 0x56
		0x07 0x57
		0x02 0x58
		0x01 0x59
		0x03 0x5a
		0x02 0x5b>;
};

&qupv3_1 {
	/* HS UART Instance For LE */
	qupv3_se6_4uart: qcom,qup_uart@a98000 {
		compatible = "qcom,msm-geni-serial-hs";
		reg = <0xa98000 0x4000>;
		reg-names = "se_phys";
		interrupts-extended = <&intc GIC_SPI 363 IRQ_TYPE_LEVEL_HIGH>,
				<&tlmm 59 IRQ_TYPE_LEVEL_HIGH>;
		clock-names = "se-clk";
		clocks = <&gcc GCC_QUPV3_WRAP1_S6_CLK>;
		interconnect-names = "qup-core", "qup-config", "qup-memory";
		interconnects =
		<&clk_virt MASTER_QUP_CORE_1 &clk_virt SLAVE_QUP_CORE_1>,
		<&gem_noc MASTER_APPSS_PROC &config_noc SLAVE_QUP_1>,
		<&aggre1_noc MASTER_QUP_1 &mc_virt  SLAVE_EBI1>;
		pinctrl-names = "default", "active", "sleep", "shutdown";
		pinctrl-0 = <&qupv3_se6_default_cts>, <&qupv3_se6_default_rts>,
		<&qupv3_se6_default_tx>, <&qupv3_se6_default_rx>;
		pinctrl-1 = <&qupv3_se6_cts>, <&qupv3_se6_rts>,
		<&qupv3_se6_tx>, <&qupv3_se6_rx>;
		pinctrl-2 = <&qupv3_se6_cts>, <&qupv3_se6_rts>,
		<&qupv3_se6_tx>, <&qupv3_se6_default_rx>;
		pinctrl-3 = <&qupv3_se6_default_cts>, <&qupv3_se6_default_rts>,
		<&qupv3_se6_default_tx>, <&qupv3_se6_default_rx>;
		always-on-clock;
		qcom,auto-suspend-disable;
		status = "ok";
	};

	/* Satellite UART */
	qupv3_se3_2uart: qcom,qup_uart@a8c000 {
		compatible = "qcom,msm-geni-serial-hs";
		reg = <0xa8c000 0x4000>;
		reg-names = "se_phys";
		interrupts-extended = <&intc GIC_SPI 356 IRQ_TYPE_LEVEL_HIGH>, 
						<&tlmm 47 IRQ_TYPE_LEVEL_HIGH>;
		clock-names = "se-clk";
		clocks = <&gcc GCC_QUPV3_WRAP1_S3_CLK>;
		interconnect-names = "qup-core", "qup-config", "qup-memory";
		interconnects =
		<&clk_virt MASTER_QUP_CORE_1 &clk_virt SLAVE_QUP_CORE_1>,
		<&gem_noc MASTER_APPSS_PROC &config_noc SLAVE_QUP_1>,
		<&aggre1_noc MASTER_QUP_1 &mc_virt  SLAVE_EBI1>;
		pinctrl-names = "default", "active", "sleep", "shutdown";
		pinctrl-0 = <&qupv3_se3_default_tx>, <&qupv3_se3_default_rx>;
		pinctrl-1 = <&qupv3_se3_tx>, <&qupv3_se3_rx>;
		pinctrl-2 = <&qupv3_se3_tx>, <&qupv3_se3_default_rx>;
		pinctrl-3 = <&qupv3_se3_default_tx>, <&qupv3_se3_default_rx>;
		qcom,auto-suspend-disable;
		status = "ok";
	};
};

&qupv3_2 {
	qupv3_se13_2uart: qcom,qup_uart@894000 {
		compatible = "qcom,msm-geni-serial-hs";
		reg = <0x894000 0x4000>;
		reg-names = "se_phys";
		interrupts-extended = <&intc GIC_SPI 587 IRQ_TYPE_LEVEL_HIGH>;
		clock-names = "se-clk";
		clocks = <&gcc GCC_QUPV3_WRAP2_S5_CLK>;
		interconnect-names = "qup-core", "qup-config", "qup-memory";
		interconnects =
		<&clk_virt MASTER_QUP_CORE_2 &clk_virt SLAVE_QUP_CORE_2>,
		<&gem_noc MASTER_APPSS_PROC &config_noc SLAVE_QUP_2>,
		<&aggre2_noc MASTER_QUP_2 &mc_virt  SLAVE_EBI1>;
		pinctrl-names = "default", "sleep";
		pinctrl-0 = <&qupv3_se13_2uart_tx_active>, <&qupv3_se13_2uart_rx_active>;
		pinctrl-1 = <&qupv3_se13_2uart_sleep>;
		qcom,auto-suspend-disable;
		status = "ok";
	};

	/* HS UART Instance for bluetooth1*/
	qupv3_se10_4uart: qcom,qup_uart@888000 {
		compatible = "qcom,msm-geni-serial-hs";
		reg = <0x888000 0x4000>;
		reg-names = "se_phys";
		interrupts-extended = <&intc GIC_SPI 584 IRQ_TYPE_LEVEL_HIGH>,
				<&tlmm 123 IRQ_TYPE_LEVEL_HIGH>;
		clock-names = "se-clk";
		clocks = <&gcc GCC_QUPV3_WRAP2_S2_CLK>;
		interconnect-names = "qup-core", "qup-config", "qup-memory";
		interconnects =
				<&clk_virt MASTER_QUP_CORE_2 &clk_virt SLAVE_QUP_CORE_2>,
				<&gem_noc MASTER_APPSS_PROC &config_noc SLAVE_QUP_2>,
				<&aggre2_noc MASTER_QUP_2 &mc_virt  SLAVE_EBI1>;
		pinctrl-names = "default", "active", "sleep", "shutdown";
		pinctrl-0 = <&qupv3_se10_default_cts>, <&qupv3_se10_default_rts>,
				<&qupv3_se10_default_tx>, <&qupv3_se10_default_rx>;
		pinctrl-1 = <&qupv3_se10_cts>, <&qupv3_se10_rts>,
				<&qupv3_se10_tx>, <&qupv3_se10_rx>;
		pinctrl-2 = <&qupv3_se10_cts>, <&qupv3_se10_rts>,
				<&qupv3_se10_tx>, <&qupv3_se10_default_rx>;
		pinctrl-3 = <&qupv3_se10_default_cts>, <&qupv3_se10_default_rts>,
				<&qupv3_se10_default_tx>, <&qupv3_se10_default_rx>;
		qcom,auto-suspend-disable;
		status = "ok";
	};
};

&qupv3_0_i2c_hub {
	/* I2C For MFI */
	qupv3_hub_i2c3: i2c@98c000  {
		qcom,clk-freq-out = <400000>;
		status = "ok";
	};
};

/* bt1 RM QUP2_SE2(8 9 10 11) from resolved gpios */
&tlmm {
	qcom,gpios-reserved = <42 43 74>;
};

&qupv3_se10_spi {
	status = "disabled";
};

&pm8550b_eusb2_repeater {
	status = "disabled";
};

&qupv3_hub_i2c0 {
	status = "ok";
	nxp_eusb2_repeater: eusb2_repeater@4f {
		compatible = "nxp,eusb2-repeater";
		reg = <0x4f>;
		vdd18-supply = <&L15B>;
		vdd3-supply = <&L5B>;
		reset-gpio = <&pm8550vs_c_gpios 4 GPIO_ACTIVE_HIGH>;
		pinctrl-names = "default";
		pinctrl-0 = <&eusb2_reset_ctrl_default>;
		qcom,param-override-seq =
			<0x40 0x06
			0x22 0x07
			0x63 0x08>;
	};
};

&eusb2_phy0 {
	dummy-supply = <&nxp_eusb2_repeater>;
	usb-repeater = <&nxp_eusb2_repeater>;
};

&aliases {
	hsuart2 = "/soc/qcom,qupv3_1_geni_se@ac0000/qcom,qup_uart@a98000";
	hsuart3 = "/soc/qcom,qupv3_2_geni_se@8c0000/qcom,qup_uart@888000";
	spi2 = "/soc/qcom,qupv3_1_geni_se@ac0000/spi@a84000";
	i2c5 = "/soc/qcom,qupv3_i2c_geni_se@9c0000/i2c@98c000";
};

&aliases {
	spi3 = "/soc/qcom,qupv3_1_geni_se@ac0000/spi@a90000";
	hsuart4 = "/soc/qcom,qupv3_2_geni_se@8c0000/qcom,qup_uart@894000";
	hsuart5 = "/soc/qcom,qupv3_1_geni_se@ac0000/qcom,qup_uart@a8c000";
};

&battery_charger {
	status = "disabled";
	qcom,shutdown-voltage = <3150>;
	mi,support-shutdown-delay;
};

&ucsi {
	status = "disabled";
};

&pcie0 {
	qcom,no-l0s-supported;
	qcom,no-l1-supported;
	qcom,no-l1ss-supported;
};

&pcie1 {
	status = "ok";
	qcom,no-l0s-supported;
	qcom,no-l1-supported;
	qcom,no-l1ss-supported;
	qcom,target-link-speed = <0x2>;
	
	qcom,boot-option = <0x0>;
	pinctrl-names = "default", "sleep";
	pinctrl-0 = <&pcie1_perst_default>;
	pinctrl-1 = <&pcie1_perst_default>;
};

&reserved_memory {
	brcm_xgbe_mem: brcm_xgbe_region {
		compatible = "shared-dma-pool";
		alloc-ranges = <0x0 0x00000000 0x0 0xffffffff>;
		reusable;
		alignment = <0x0 0x400000>;
		size = <0x0 0x2000000>;
	};
};

&pcie1_rp {
	#address-cells = <5>;
	#size-cells = <0>;

	brcm_xgbe_pci: brcm_xgbe_pci {
		reg = <0 0 0 0 0>;
		qcom,iommu-group = <&brcm_xgbe_pci_iommu_group1>;
		memory-region = <&brcm_xgbe_mem>;

		#address-cells = <1>;
		#size-cells = <1>;
		brcm_xgbe_pci_iommu_group1: brcm_xgbe_pci_iommu_group1 {
			qcom,iommu-msi-size = <0x1000>;
			qcom,iommu-dma-addr-pool = <0x98000000 0x18000000>;
			qcom,iommu-geometry = <0x98000000 0x18010000>;
			qcom,iommu-dma = "fastmap";
			qcom,iommu-pagetable = "coherent";
			qcom,iommu-faults = "stall-disable", "HUPCF", "no-CFRE",
					    "non-fatal";
		};
	};
};

&sdhc_2 {
	status = "ok";
	vdd-supply = <&pm_humu_l9>;
	qcom,vdd-voltage-level = <2950000 3104000>;
	qcom,vdd-current-level = <0 800000>;
	vdd-io-supply = <&pm_humu_l8>;
	qcom,vdd-io-voltage-level = <1800000 1800000>;
	qcom,vdd-io-current-level = <0 10000>;
	qcom,vdd-io-always-on;
	non-removable;
	no-sd;
	qcom,core_3_0v_support;
	keep-power-in-suspend;
	pinctrl-names = "default", "sleep";
	pinctrl-0 = <&sdc2_on>, <&sdc2_wlan_en_active>;
	pinctrl-1 = <&sdc2_off>, <&sdc2_wlan_en_sleep>;
	resets = <&gcc GCC_SDCC2_BCR>;
	reset-names = "core_reset";
	qcom,iommu-dma = "fastmap";
	qcom,uses_level_shifter;
};

&soc {
        bcmdhd_wlan: bcmdhd_wlan {
                compatible = "android,bcmdhd_wlan";
                wlan-en-gpio = <&tlmm 121 GPIO_ACTIVE_HIGH>;
        };
};
