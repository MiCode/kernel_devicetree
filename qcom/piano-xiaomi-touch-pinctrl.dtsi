&soc {
	xiaomi_touch {
		compatible = "xiaomi-touch";
		status = "ok";
		touch,name = "xiaomi-touch";
	};

};


&tlmm {
	mi_ts_spi_clk_suspend: mi_ts_spi_clk_suspend {
		mux {
			pins = "gpio42";
			function = "gpio";
		};

		config {
			pins = "gpio42";
			drive-strength = <2>;
			bias-pull-down;
		};
	};

	mi_ts_spi_mosi_suspend: mi_ts_spi_mosi_suspend {
		mux {
			pins = "gpio41";
			function = "gpio";
		};

		config {
			pins = "gpio41";
			drive-strength = <2>;
			output-low;
			bias-disable;
		};
	};

	mi_ts_spi_miso_suspend: mi_ts_spi_miso_suspend {
		mux {
			pins = "gpio40";
			function = "gpio";
		};

		config {
			pins = "gpio40";
			drive-strength = <2>;
			output-low;
			bias-disable;
		};
	};

	mi_ts_spi_cs_active: mi_ts_spi_cs_active {
		mux {
			pins = "gpio43";
			function = "qup1_se2_l3";
		};

		config {
			pins = "gpio43";
			drive-strength = <6>;
			bias-disable;
		};
	};

	mi_ts_spi_cs_suspend: mi_ts_spi_cs_suspend {
		mux {
			pins = "gpio43";
			function = "gpio";
		};

		config {
			pins = "gpio43";
			drive-strength = <6>;
			bias-pull-down;
			output-low;
		};
	};
};

&qupv3_se2_i2c {
  status = "disabled";
};


&qupv3_se2_spi {
	status = "ok";
	qcom,rt;
	pinctrl-0 = <&qupv3_se2_spi_mosi_active>, <&qupv3_se2_spi_miso_active>,
				<&qupv3_se2_spi_clk_active>;
	pinctrl-1 = <&mi_ts_spi_mosi_suspend>, <&mi_ts_spi_miso_suspend>,
				<&mi_ts_spi_clk_suspend>;

	novatek@0 {
		compatible = "novatek,NVT-ts-spi";
		reg = <0>; //Same as CS ID
		status = "ok";

		spi-max-frequency = <19200000>;	//4800000,9600000,15000000,19200000
		//novatek,reset-gpio = <&tlmm 2 0x00>;
		novatek,irq-gpio = <&tlmm 162 0x2001>;
		novatek,lcd_id-gpio = <&tlmm 100 0x00>;
		pinctrl-0 = <&mi_ts_spi_cs_active>;
		pinctrl-1 = <&mi_ts_spi_cs_suspend>;
		pinctrl-names = "pmx_ts_active", "pmx_ts_suspend";

		novatek,pen-support;
		novatek,stylus-resol-double;

		//novatek,spi-rd-fast-addr = <0x03F310>;

		/* MP */
		novatek,mp-support-dt;

		/*new touch feature default param*/
		novatek,touch-game-param-config1 = <2 2 1 2 1>;
		novatek,touch-game-param-config2 = <2 2 2 2 1>;
		novatek,touch-game-param-config3 = <2 2 3 2 1>;

		/* xiaomi touch default param */
		mi_tp,game-mode-array =
						<1 0 0 0 0>;  /* MAX MIN DEF SET GET */
		mi_tp,active-mode-array =
						<1 0 0 0 0>;  /* MAX MIN DEF SET GET */
		mi_tp,tolerance-array =
						<4 0 2 2 2>;  /* MAX MIN DEF SET GET */
		mi_tp,up-threshold-array =
						<4 0 3 3 3>;  /* MAX MIN DEF SET GET */
		mi_tp,aim-sensitivity-array =
						<4 0 2 2 2>;  /* MAX MIN DEF SET GET */
		mi_tp,tap-stability-array =
						<4 0 2 2 2>;  /* MAX MIN DEF SET GET */
		mi_tp,edge-filter-array =
						<3 0 2 2 2>;  /* MAX MIN DEF SET GET */
		mi_tp,panel-orien-array =
						<3 0 0 0 0>;  /* MAX MIN DEF SET GET */
		mi_tp,report-rate-array =
						<3 0 0 0 0>;  /* MAX MIN DEF SET GET */
		mi_tp,expert-mode-array =
						<3 1 1 1 1>;  /* MAX MIN DEF SET GET */

		/* for Xiaomi P81 NT36532E BOE11.16" panel module */
		novatek-mp-criteria-59B0@0 {
			#address-cells = <1>;
			#size-cells = <0>;
			compatible = "novatek-mp-criteria-59B0";

			/* MP Config */
			IC_X_CFG_SIZE = <60>;
			IC_Y_CFG_SIZE = <40>;
