&soc {
 	thermal-message {
  		board-sensor = "VIRTUAL-SENSOR0";
 	};
 };

&qupv3_se10_i2c {
	status = "ok";
	qcom,clk-freq-out = <400000>;
	ntag@57 {
		compatible = "fm,fm19511";
		reg = <0x57>;
		//qcom,ntag-vdd-supply = <&L16B>;
		//qcom,ntag-vdd-voltage = <3300000 3300000>;
		//qcom,ntag-vdd-current = <60000>;
		qcom,ntag-irq = <&tlmm 209 0x00>;

		interrupt-parent = <&tlmm>;
		interrupts = <209 0>;
		interrupt-names = "ntag_irq";
		pinctrl-names = "default","suspend";
		pinctrl-0 = <&ntag_int_default>;
		pinctrl-1 = <&ntag_int_suspend>;
	};
};

&usb0 {
	qcom,wcd_usbss = <&wcd_usbss>;
	wcd_equ = <0xB0>;
	wcd_equ_host = <0xB0>;
};
&dwc3_0 {
	usb-phy = <&eusb2_phy0>, <&usb_qmp_dp_phy>;
	maximum-speed = "super-speed";
};
&pmih010x_eusb2_repeater {
	qcom,host-param-override-seq =
		<0x00 0x50
		0x0F 0x51
		0x02 0x52
		0x07 0x53
		0x01 0x54
		0x03 0x55
		0x03 0x56
		0x05 0x57
		0x02 0x58
		0x03 0x59
		0x01 0x5a
		0x02 0x5b>;
	qcom,param-override-seq =
		<0x00 0x50
		0x0E 0x51
		0x01 0x52
		0x07 0x53
		0x03 0x54
		0x03 0x55
		0x00 0x56
		0x06 0x57
		0x02 0x58
		0x03 0x59
		0x01 0x5a
		0x02 0x5b>;
};
&usb_qmp_dp_phy {
	usb3,eyegram-tuning;
	qcom,usb3-phy-eye-seq =
	/* <reg_offset, value>*/
		<USB3_DP_PCS_G12S1_TXMGN_V0 0x1F
			USB3_DP_PCS_G12S1_TXDEEMPH_M3P5DB 0x19>;
	qcom,host-usb3-phy-eye-seq =
		<USB3_DP_PCS_G12S1_TXMGN_V0 0x1F
			USB3_DP_PCS_G12S1_TXDEEMPH_M3P5DB 0x19>;
};

/*Remove PM8010 N for hardware design*/
&regulator_ocp_notifier {
	/delete-property/ periph-d40-supply;
	/delete-property/ periph-d41-supply;
	/delete-property/ periph-d42-supply;
	/delete-property/ periph-d43-supply;
	/delete-property/ periph-d44-supply;
	/delete-property/ periph-d45-supply;
	/delete-property/ periph-d46-supply;
};

&soc {
	xiaomi_mi_trace{
		compatible = "xiaomi,mi_trace";
		mt-size = <0x100000>;
	};
};

/* keyboard start */
&tlmm {
	nanosic_keyboard_mcu {
			xiaomi_keyboard_sleep_default: xiaomi_keyboard_sleep_default {
				mux {
					pins = "gpio3";
					function = "gpio";
				};
				config {
					pins = "gpio3";
					drive-strength = <2>;
					bias-pull-down;
				};
			};
			xiaomi_keyboard_default:xiaomi_keyboard_default {
				mux {
					pins = "gpio188", "gpio95";
					function = "gpio";
				};
				config {
					pins = "gpio188", "gpio95";
					drive-strength = <2>;
					bias-disable;
				};
			};
		};
		mi_qupv3_se6_i2c_pins: mi_qupv3_se6_i2c_pins {
			mi_qupv3_se6_i2c_sda_active: mi_qupv3_se6_i2c_sda_active {
				mux {
					pins = "gpio56";
					function = "qup1_se6_l0";
				};

				config {
					pins = "gpio56";
					drive-strength = <2>;
					bias-disable;
				};
			};

			mi_qupv3_se6_i2c_scl_active: mi_qupv3_se6_i2c_scl_active {
				mux {
					pins = "gpio57";
					function = "qup1_se6_l1";
				};

				config {
					pins = "gpio57";
					drive-strength = <2>;
					bias-disable;
				};
			};
			mi_qupv3_se6_i2c_sleep: mi_qupv3_se6_i2c_sleep {
				mux {
					pins = "gpio56", "gpio57";
					function = "gpio";
				};
				config {
					pins = "gpio56", "gpio57";
					drive-strength = <2>;
					bias-disable;
				};
			};
    };
};


&qupv3_se6_i2c {
  status = "ok";
  pinctrl-names = "default", "sleep"; /*Cancel I2C pull-up*/
  pinctrl-0 = <&mi_qupv3_se6_i2c_sda_active>, <&mi_qupv3_se6_i2c_scl_active>;
  pinctrl-1 = <&mi_qupv3_se6_i2c_sleep>;
  qcom,clk-freq-out = <1000000>;
  nanosic@4c{
    compatible = "nanosic,803";
    reg = <0x4c>;
    pinctrl-names = "default";
    pinctrl-0 = <&xiaomi_keyboard_sleep_default &xiaomi_keyboard_default>;
    irq_pin = <&tlmm 97 0x2001>;/*IRQF_ONESHOT | IRQF_TRIGGER_RISING */
    reset_pin  = <&tlmm 188 0x00>;
    status_pin = <&tlmm 95 0x00>;
    sleep_pin = <&tlmm 3 0x00>;
    nanosic,vdd-name = "vdd";
    vdd-supply = <&L14B>;
    nanosic,dvdd-name = "dvdd";
    dvdd-supply = <&L11B>;

    /*Select edge_filter param according to pid number*/
    touchpad-configs {
        pid_1260 {
            compatible = "nanosic-pid-1260";
            touchpad,edge-area-left-min = <0>;
            touchpad,edge-area-left-max = <320>;
            touchpad,edge-area-right-min = <2879>;
            touchpad,edge-area-right-max = <3199>;
            touchpad,edge-area-top-min = <0>;
            touchpad,edge-area-top-max = <427>;
            touchpad,edge-area-bottom-min = <1708>;
            touchpad,edge-area-bottom-max = <2135>;
            touchpad,shield-frame-count-limit = <140>;
            touchpad,one-swipe-dis-limit = <40000>;
            touchpad,two-swipe-dis-limit = <2500>;
            touchpad,two-pinch-dis-limit = <2500>;
            touchpad,three-swipe-dis-limit = <10000>;
            touchpad,two-fingers-gesture-dis = <925444>; // (sqrt(X^2+Y^2)*0.25)^2
        };

        pid_1294 {
            compatible = "nanosic-pid-1294";
            touchpad,edge-area-left-min = <0>;
            touchpad,edge-area-left-max = <320>;
            touchpad,edge-area-right-min = <2879>;
            touchpad,edge-area-right-max = <3199>;
            touchpad,edge-area-top-min = <0>;
            touchpad,edge-area-top-max = <213>;
            touchpad,edge-area-bottom-min = <1922>;
            touchpad,edge-area-bottom-max = <2135>;
            touchpad,shield-frame-count-limit = <140>;
            touchpad,one-swipe-dis-limit = <40000>;
            touchpad,two-swipe-dis-limit = <2500>;
            touchpad,two-pinch-dis-limit = <2500>;
            touchpad,three-swipe-dis-limit = <10000>;
            touchpad,two-fingers-gesture-dis = <925444>; // (sqrt(X^2+Y^2)*0.25)^2
        };

        pid_1294_extend {
            compatible = "pid_1294_extend";
            touchpad,edge-area-left-min = <0>;
            touchpad,edge-area-left-max = <320>;
            touchpad,edge-area-right-min = <2879>;
            touchpad,edge-area-right-max = <3199>;
            touchpad,edge-area-top-min = <0>;
            touchpad,edge-area-top-max = <640>;
            touchpad,edge-area-bottom-min = <1495>;
            touchpad,edge-area-bottom-max = <2135>;
            touchpad,shield-frame-count-limit = <140>;
            touchpad,one-swipe-dis-limit = <250000>;
            touchpad,two-swipe-dis-limit = <2500>;
            touchpad,two-pinch-dis-limit = <2500>;
            touchpad,three-swipe-dis-limit = <10000>;
            touchpad,two-fingers-gesture-dis = <925444>; // (sqrt(X^2+Y^2)*0.25)^2
        };
    };
  };
};

&qupv3_se6_spi{
	status = "disabled";
};

&L14B {
	regulator-min-microvolt = <3300000>;
	regulator-max-microvolt = <3300000>;
};

&L11B {
	regulator-min-microvolt = <1800000>;
	regulator-max-microvolt = <1800000>;
};

/* keyboard end */

/* start: remove modem reserve memory and node */
&mpss_mem {
	status = "disabled";
};

&modem_pas {
	status = "no";
};
/* end: remove modem reserve memory and node */