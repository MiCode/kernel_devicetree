&dwc3_0 {
	usb-phy = <&eusb2_phy0>, <&usb_qmp_dp_phy>;
	maximum-speed = "super-speed";
};
&usb_qmp_dp_phy {
	usb3,eyegram-tuning;
	qcom,usb3-phy-eye-seq =
		<USB3_DP_PCS_G12S1_TXMGN_V0 0x1F
			USB3_DP_PCS_G12S1_TXDEEMPH_M3P5DB 0x17>;
	qcom,host-usb3-phy-eye-seq =
		<USB3_DP_PCS_G12S1_TXMGN_V0 0x1F
			USB3_DP_PCS_G12S1_TXDEEMPH_M3P5DB 0x17>;
};
&pm7550ba_eusb2_repeater {
	qcom,host-param-override-seq =
		<0x00 0x50
		0x09 0x51
		0x04 0x52
		0x07 0x53
		0x02 0x54
		0x03 0x55
		0x00 0x56
		0x05 0x57
		0x02 0x58
		0x03 0x59
		0x03 0x5a
		0x02 0x5b>;
	qcom,param-override-seq =
		<0x00 0x50
		0x0A 0x51
		0x01 0x52
		0x07 0x53
		0x02 0x54
		0x03 0x55
		0x03 0x56
		0x06 0x57
		0x02 0x58
		0x03 0x59
		0x01 0x5a
		0x02 0x5b>;
	qcom,param-override-seq-host-ms =
		<0x00 0x50
		0x0F 0x51
		0x04 0x52
		0x07 0x53
		0x02 0x54
		0x03 0x55
		0x00 0x56
		0x05 0x57
		0x02 0x58
		0x03 0x59
		0x03 0x5a
		0x02 0x5b>;
};

&qupv3_se9_i2c {
	status = "ok";
	qcom,clk-freq-out = <400000>;
	ntag@57 {
		compatible = "fm,fm19511";
		reg = <0x57>;
		qcom,ntag-vdd-supply = <&L21B>;
		qcom,ntag-vdd-voltage = <3300000 3300000>;
		qcom,ntag-vdd-current = <60000>;
		qcom,ntag-irq = <&tlmm 69 0x00>;

		interrupt-parent = <&tlmm>;
		interrupts = <69 0>;
		interrupt-names = "ntag_irq";
		pinctrl-names = "default","suspend";
		pinctrl-0 = <&ntag_int_default>;
		pinctrl-1 = <&ntag_int_suspend>;
	};
};

&qupv3_se10_spi {
	status = "ok";
	ir-spi@0 {
		compatible = "ir-spi";
		reg = <0>;
		spi-max-frequency = <19200000>;
		status = "ok";
	};
};

/* touch start */

&soc {
	xiaomi_touch {
		compatible = "xiaomi-touch";
		status = "ok";
		touch,name = "xiaomi-touch";
	};
};

&qupv3_se4_i2c {
  status = "disabled";
};

&tlmm {
	mi_ts_spi_miso_active: mi_ts_spi_miso_active {
		mux {
			pins = "gpio16";
			function = "qup1_se4_l0";
		};
		config {
			pins = "gpio16";
			drive-strength = <6>;
			bias-disable;
		};
	};
	mi_ts_spi_mosi_active: mi_ts_spi_mosi_active {
		mux {
			pins = "gpio17";
			function = "qup1_se4_l1";
		};
		config {
			pins = "gpio17";
			drive-strength = <6>;
			bias-disable;
		};
	};
	mi_ts_spi_clk_active: mi_ts_spi_clk_active {
		mux {
			pins = "gpio18";
			function = "qup1_se4_l2";
		};
		config {
			pins = "gpio18";
			drive-strength = <6>;
			bias-disable;
		};
	};
	mi_ts_spi_cs_active: mi_ts_spi_cs_active {
		mux {
			pins = "gpio19";
			function = "qup1_se4_l3";
		};
		config {
			pins = "gpio19";
			drive-strength = <6>;
			bias-disable;
		};
	};
	mi_ts_spi_cs_suspend: mi_ts_spi_cs_suspend {
		mux {
			pins = "gpio19";
			function = "gpio";
		};
		config {
			pins = "gpio19";
			drive-strength = <2>;
			bias-pull-down;
			output-low;
		};
	};
	mi_ts_spi_sleep: mi_ts_spi_sleep {
		mux {
			pins = "gpio16", "gpio17";
			function = "gpio";
		};
		config {
			pins = "gpio16", "gpio17";
			drive-strength = <2>;
			output-low;
			bias-disable;
		};
	};
	mi_ts_clk_sleep: mi_ts_clk_sleep {
		mux {
			pins = "gpio18";
			function = "gpio";
		};
		config {
			pins = "gpio18";
			drive-strength = <2>;
			bias-pull-down;
		};
	};
};

&qupv3_se4_spi {
	status = "ok";
	qcom,rt;
	pinctrl-0 = <&mi_ts_spi_mosi_active>, <&mi_ts_spi_miso_active>,
				<&mi_ts_spi_clk_active>;
	pinctrl-1 = <&mi_ts_spi_sleep>, <&mi_ts_clk_sleep>;
	/* Novatek device tree node */
	novatek@0 {
		compatible = "novatek,NVT-ts-spi";
		reg = <0>; //Same as CS ID
		status = "ok";

		spi-max-frequency = <19200000>;	//4800000,9600000,15000000,19200000
		//novatek,reset-gpio = <&tlmm 14 0x00>;
		novatek,irq-gpio = <&tlmm 78 0x2008>;
		novatek,lcd_id-gpio = <&tlmm 27 0x00>;
		spi-cs-setup-delay-ns = <300>;
 		spi-cs-hold-delay-ns = <300>;
		pinctrl-0 = <&mi_ts_spi_cs_active>;
		pinctrl-1 = <&mi_ts_spi_cs_suspend>;
		pinctrl-names = "pmx_ts_active", "pmx_ts_suspend";

		novatek,pen-support;
		novatek,stylus-resol-double;

		//novatek,spi-rd-fast-addr = <0x03F310>;

		/* MP */
		novatek,mp-support-dt;

		/*new touch feature default param*/
		novatek,touch-game-param-config1 = <2 2 1 2 1>;
		novatek,touch-game-param-config2 = <2 2 2 2 1>;
		novatek,touch-game-param-config3 = <2 2 3 2 1>;

		/* xiaomi touch default param */
		mi_tp,game-mode-array =
						<1 0 0 0 0>;  /* MAX MIN DEF SET GET */
		mi_tp,active-mode-array =
						<1 0 0 0 0>;  /* MAX MIN DEF SET GET */
		mi_tp,tolerance-array =
						<4 0 2 2 2>;  /* MAX MIN DEF SET GET */
		mi_tp,up-threshold-array =
						<4 0 3 3 3>;  /* MAX MIN DEF SET GET */
		mi_tp,aim-sensitivity-array =
						<4 0 2 2 2>;  /* MAX MIN DEF SET GET */
		mi_tp,tap-stability-array =
						<4 0 2 2 2>;  /* MAX MIN DEF SET GET */
		mi_tp,edge-filter-array =
						<3 0 2 2 2>;  /* MAX MIN DEF SET GET */
		mi_tp,panel-orien-array =
						<3 0 0 0 0>;  /* MAX MIN DEF SET GET */
		mi_tp,report-rate-array =
						<3 0 0 0 0>;  /* MAX MIN DEF SET GET */
