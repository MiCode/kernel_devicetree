&mca_strategy_buckchg_class {
	status = "ok";
	in_pps = <2500>;
	chg_pps = <3500>;
	batt_type = <1>;
	pmic_fv_compensation = <40>;
	ffc_temp_low = <18>;
	ffc_temp_high = <48>;
