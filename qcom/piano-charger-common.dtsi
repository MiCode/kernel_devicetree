#include "mca.dtsi"

&tlmm {
	charger_cp_int_master: charger_cp_int_master {
		mux {
			pins = "gpio68";
			function = "gpio";
		};
		config {
			pins = "gpio68";
			drive-strength = <2>;   /* 2 mA */
			bias-disable;
		};
	};

	fg_batt_ctl_master: fg_batt_ctl_master {
		mux {
			pins = "gpio112";
			function = "gpio";
		};
		config {
			pins = "gpio112";
			drive-strength = <2>;
			bias-pull-down;
			output-enable;
		};
	};

	fg_batt_ctl_slave: fg_batt_ctl_slave {
		mux {
			pins = "gpio113";
			function = "gpio";
		};
		config {
			pins = "gpio113";
			drive-strength = <2>;
			bias-pull-down;
			output-enable;
		};
	};

	wls_int_default: wls_int_default {
		mux {
			pins = "gpio78";
			function = "gpio";
		};
		config {
			pins = "gpio78";
			drive-strength = <2>;   /* 2 mA */
			bias-pull-up;
			qcom,apps;
		};
	};

	wls_sw_default: wls_sw_default {
		mux {
			pins = "gpio14";
			function = "gpio";
		};
		config {
			pins = "gpio14";
			drive-strength = <2>;
			output-low;
			bias-disable;
			qcom,apps;
		};
	};

	wls_boost_default: wls_boost_default {
		mux {
			pins = "gpio120";
			function = "gpio";
		};
		config {
			pins = "gpio120";
			drive-strength = <2>;
			output-low;
			qcom,apps;
		};
	};

	hall3_int_default: hall3_int_default {
		mux {
			pins = "gpio200";
			function = "gpio";
		};
		config {
			pins = "gpio200";
			drive-strength = <2>;
			input-enable;
			bias-pull-up;
			qcom,apps;
		};
	};

	hall4_int_default: hall4_int_default {
		mux {
			pins = "gpio196";
			function = "gpio";
		};
		config {
			pins = "gpio196";
			drive-strength = <2>;
			input-enable;
			bias-pull-up;
			qcom,apps;
		};
	};

	hall_ppe_int_default: hall_ppe_int_default {
		mux {
			pins = "gpio55";
			function = "gpio";
		};
		config {
			pins = "gpio55";
			drive-strength = <2>;
			input-enable;
			bias-pull-up;
			qcom,apps;
		};
	};

	hall3_s_int_default: hall3_s_int_default {
		mux {
			pins = "gpio201";
			function = "gpio";
		};
		config {
			pins = "gpio201";
			drive-strength = <2>;
			input-enable;
			bias-pull-up;
			qcom,apps;
		};
	};

	hall4_s_int_default: hall4_s_int_default {
		mux {
			pins = "gpio197";
			function = "gpio";
		};
		config {
			pins = "gpio197";
			drive-strength = <2>;
			input-enable;
			bias-pull-up;
			qcom,apps;
		};
	};

	hall_ppe_s_int_default: hall_ppe_s_int_default {
		mux {
			pins = "gpio59";
			function = "gpio";
		};
		config {
			pins = "gpio59";
			drive-strength = <2>;
			input-enable;
			bias-pull-up;
			qcom,apps;
		};
	};

	lp_nen_default: lp_nen_default {
		mux {
			pins = "gpio99";
			function = "gpio";
		};
		config {
			pins = "gpio99";
			drive-strength = <2>;
			output-high;
			bias-disable;
			qcom,apps;
		};
	};
};

&qupv3_se5_i2c {
	status = "ok";
	#address-cells = <1>;
	#size-cells = <0>;
	bq27z561_master@55 {
		compatible = "ti,bq27z561_master";
		ic_role = <0>;
		reg = <0x55>;
		batt_ctl = <&tlmm 112 0>;
		pinctrl-0 = <&fg_batt_ctl_master>;
		unseal_key = /bits/ 8 <0x3b 0x30 0xb9 0x8a>;
		bq,charge-full-design = <4620>;
		soh_th = <92>;
		cycle_th = <400>;
		cycle_step = <50>;
		resistance-id = <100000>;
		co_by_gpio;
		status = "ok";
	};

	sc8541_master@6a {
		compatible = "sc8541_master";
		status = "ok";
		ic_role = <0>;
		reg = <0x6a>;
		cp-int= <&tlmm 68 0>;
		pinctrl-names = "default";
		pinctrl-0 =  <&charger_cp_int_master>;
		bat-ovp-threshold = <4800>;
		bat-ovp-alarm-threshold = <4600>;
		bus-ovp-threshold = <13000 13000>;
		bus-ocp-threshold = <7000 7000>;
		usb-ovp-threshold = <14000 14000>;
	};
};


&qupv3_se11_i2c {
	status = "ok";
	#address-cells = <1>;
	#size-cells = <0>;

	bq27z561_slave@55 {
		compatible = "ti,bq27z561_slave";
		ic_role = <1>;
		reg = <0x55>;
		batt_ctl = <&tlmm 113 0>;
		pinctrl-0 = <&fg_batt_ctl_slave>;
		unseal_key = /bits/ 8 <0x3b 0x30 0xb9 0x8a>;
		bq,charge-full-design = <4620>;
		soh_th = <92>;
		cycle_th = <400>;
		cycle_step = <50>;
		resistance-id = <100000>;
		co_by_gpio;
		status = "ok";
	};
};

&qupv3_se13_i2c {
	status = "ok";
	#address-cells = <1>;
	#size-cells = <0>;

	sc96231@38 {
		compatible = "sc,sc96231-wireless-charger";
		reg = <0x38>;
		rx_role = <0>;
		project_vendor = <5>;
		fw_version_index = <1>;
		reverse-txon-low;
		pinctrl-names =
			"wls_int_pull_up", "wls_sw_config", "wls_boost_config", "hall3_int_pull_up",
			"hall4_int_pull_up", "hall_ppe_int_pull_up", "hall3_s_int_pull_up",
			"hall4_s_int_pull_up", "hall_ppe_s_int_pull_up", "lp_nen_pull_up";
		pinctrl-0 = <&wls_int_default>;
		pinctrl-1 = <&wls_sw_default>;
		pinctrl-2 = <&wls_boost_default>;
		pinctrl-3 = <&hall3_int_default>;
		pinctrl-4 = <&hall4_int_default>;
		pinctrl-5 = <&hall_ppe_int_default>;
		pinctrl-6 = <&hall3_s_int_default>;
		pinctrl-7 = <&hall4_s_int_default>;
		pinctrl-8 = <&hall_ppe_s_int_default>;
		pinctrl-9 = <&lp_nen_default>;
		rx-int = <&tlmm 78 0x00>;
		reverse-txon-gpio = <&tlmm 14 0x00>;
		reverse-boost-gpio = <&tlmm 120 0x00>;
		hall3-int = <&tlmm 200 0x00>;
		hall4-int = <&tlmm 196 0x00>;
		hall-ppe-int = <&tlmm 55 0x00>;
		hall3-s-int = <&tlmm 201 0x00>;
		hall4-s-int = <&tlmm 197 0x00>;
		hall-ppe-s-int = <&tlmm 59 0x00>;
		lp-nen-gpio = <&tlmm 99 0x00>;
		keyboard-front-gpio = <&tlmm 80 0x00>;
		keyboard-back-gpio = <&tlmm 11 0x00>;
	};
};

&mca_adsp_glink {
	status = "ok";
};

&mca_bc12_class {
	status = "ok";
};

&mca_qcom_subpmic_proxy {
	status = "ok";
	otg_boost_src = <0>;
	gpio_chip_type = <1>;
	mi,support-cid = <1>;
