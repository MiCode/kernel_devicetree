#include "mca.dtsi"
&tlmm {
	charger_cp_int_default: charger_cp_int_default  {
		mux {
			pins = "gpio190";
			function = "gpio";
		};
		config {
			pins = "gpio190";
			drive-strength = <2>;   /* 2 mA */
			bias-disable;
		};
	};
	onewire_gpio_pins: onewire_gpio_pins  {
		mux {
			pins = "gpio15";
			function = "gpio";
		};
		config {
			pins = "gpio15";
			drive-strength = <16>;   /* 16 mA */
			bias-disable;
		};
	};

	wls_int_default: wls_int_default {
		mux {
			pins = "gpio29";
			function = "gpio";
		};
		config {
			pins = "gpio29";
			drive-strength = <2>;   /* 2 mA */
			bias-pull-up;
			qcom,apps;
		};
	};

	hall3_int_default: hall3_int_default {
		mux {
			pins = "gpio28";
			function = "gpio";
		};
		config {
			pins = "gpio28";
			drive-strength = <2>;
			input-enable;
			bias-pull-up;
			qcom,apps;
		};
	};

	hall4_int_default: hall4_int_default {
		mux {
			pins = "gpio135";
			function = "gpio";
		};
		config {
			pins = "gpio135";
			drive-strength = <2>;
			input-enable;
			bias-pull-up;
			qcom,apps;
		};
	};

	hall_ppe_int_default: hall_ppe_int_default {
		mux {
			pins = "gpio167";
			function = "gpio";
		};
		config {
			pins = "gpio167";
			drive-strength = <2>;
			input-enable;
			bias-pull-up;
			qcom,apps;
		};
	};

	hall3_s_int_default: hall3_s_int_default {
		mux {
			pins = "gpio157";
			function = "gpio";
		};
		config {
			pins = "gpio157";
			drive-strength = <2>;
			input-enable;
			bias-pull-up;
			qcom,apps;
		};
	};

	hall4_s_int_default: hall4_s_int_default {
		mux {
			pins = "gpio137";
			function = "gpio";
		};
		config {
			pins = "gpio137";
			drive-strength = <2>;
			input-enable;
			bias-pull-up;
			qcom,apps;
		};
	};

	hall_ppe_s_int_default: hall_ppe_s_int_default {
		mux {
			pins = "gpio168";
			function = "gpio";
		};
		config {
			pins = "gpio168";
			drive-strength = <2>;
			input-enable;
			bias-pull-up;
			qcom,apps;
		};
	};

	lp_nen_default: lp_nen_default {
		mux {
			pins = "gpio98";
			function = "gpio";
		};
		config {
			pins = "gpio98";
			drive-strength = <2>;
			output-high;
			qcom,apps;
		};
	};
};

&qupv3_se11_i2c {
	status = "ok";
	#address-cells = <1>;
	#size-cells = <0>;
	sc8541_master@6a {
		compatible = "sc8541_master";
		status = "ok";
		ic_role = <0>;
		reg = <0x6a>;
		cp-int= <&tlmm 190 0>;
		pinctrl-names = "default";
		pinctrl-0 =  <&charger_cp_int_default>;
		bat-ovp-threshold = <4800>;
		bat-ovp-alarm-threshold = <4600>;
		bus-ucp-fall-deglitch = <50000>;
		bus-ovp-threshold = <13000 13000>;
		bus-ocp-threshold = <6000 6000>;
		usb-ovp-threshold = <14000 14000>;
		support-multiple-cp;
	};
	bq25960-charger@65 {
		compatible = "ti,bq25960-master";
		status = "ok";
		ic_role = <0>;
		reg = <0x65>;
		cp-int= <&tlmm 190 0>;
		ti,bq25960,bat-ovp-threshold = <4620>;
		ti,bq25960,bus-ovp-threshold = <13000>;
		ti,bq25960,bus-ocp-threshold = <4715>;
		ti,bq25960,bus-ucp-threshold = <250>;
		ti,bq25960,usb-ovp-threshold = <14000>;
		ti,bq25960,vout-ovp-threshold = <5000>;
		ti,bq25960,bat-ovp-alarm-threshold = <4580>;
		ti,bq25960,bus-ovp-alarm-threshold = <11000>;
		ti,bq25960,bus-ocp-alarm-threshold = <4200>;
		ti,bq25960,bat-ocp-disable = <1>;
		ti,bq25960,bat-ocp-alarm-disable = <1>;
		ti,bq25960,bat-therm-disable = <1>;
		ti,bq25960,bus-therm-disable = <1>;
		ti,bq25960,die-therm-threshold = <90>;
		support-multiple-cp;
	};
	bq25960h-charger@3f {
		compatible = "ti,bq25960h-master";
		status = "ok";
		ic_role = <0>;
		reg = <0x3f>;
		cp-int= <&tlmm 190 0>;
	};
};

&qupv3_se8_i2c {
	status = "ok";
	#address-cells = <1>;
	#size-cells = <0>;
	sc96231@38 {
		compatible = "sc,sc96231-wireless-charger";
		reg = <0x38>;
		rx_role = <0>;
		project_vendor = <5>;
		fw_version_index = <0>;
		pinctrl-names =
			"wls_int_pull_up", "hall3_int_pull_up", "hall4_int_pull_up", "hall_ppe_int_pull_up",
			"hall3_s_int_pull_up", "hall4_s_int_pull_up", "hall_ppe_s_int_pull_up", "lp_nen_pull_up";
		pinctrl-0 = <&wls_int_default>;
		pinctrl-1 = <&hall3_int_default>;
		pinctrl-2 = <&hall4_int_default>;
		pinctrl-3 = <&hall_ppe_int_default>;
		pinctrl-4 = <&hall3_s_int_default>;
		pinctrl-5 = <&hall4_s_int_default>;
		pinctrl-6 = <&hall_ppe_s_int_default>;
		pinctrl-7 = <&lp_nen_default>;
		rx-int = <&tlmm 29 0x00>;
		reverse-txon-gpio = <&tlmm 38 0x00>;
		reverse-boost-gpio = <&tlmm 79 0x00>;
		hall3-int = <&tlmm 28 0x00>;
		hall4-int = <&tlmm 135 0x00>;
		hall-ppe-int = <&tlmm 167 0x00>;
		hall3-s-int = <&tlmm 157 0x00>;
		hall4-s-int = <&tlmm 137 0x00>;
		hall-ppe-s-int = <&tlmm 168 0x00>;
		lp-nen-gpio = <&tlmm 98 0x00>;
		keyboard-front-gpio = <&tlmm 134 0x00>;
		keyboard-back-gpio = <&tlmm 46 0x00>;
	};
};

