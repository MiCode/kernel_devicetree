&soc {
	mca_qcom_battery_gauge: mca_qcom_battery_gauge {
		compatible = "mca,qcom-battery-gauge";
		status = "ok";
/*
		normal-temp-zones =
				<15 4485 800>,
				<48 4465 800>,
				<60 4100 800>;
		ffc-temp-zones-nvt =
				<35 4510 2800>,
				<48 4510 4350>;
		ffc-temp-zones-swd =
				<35 4510 2800>,
				<48 4510 3800>;
*/
		buck-vbatt-full-delta = <25>;
		buck-ibatt-full-delta = <250>;

		// Default fallback using full-delta value if no matching entry found in ibatt-full-table
		quick-vbatt-full-delta = <7>;
		quick-ibatt-full-delta = <800>;

		quick-ibatt-full-table-swd =
				<565  1000>,
				<2200 2800>,
				<2825 3800>;
		quick-ibatt-full-table-nvt =
				<565  1000>,
				<2260 2800>,
				<3390 4350>;
	};

	mca_onewire_core: mca_onewire_core {
		compatible = "mca,onewire-core";
		status = "ok";
		pinctrl-names = "default";
		pinctrl-0 = <&onewire_gpio_pins>;
		gpios = <&tlmm 15 0>;
